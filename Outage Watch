#!/usr/bin/env python3
"""
DEDDIE Planned Power Outage Watcher
------------------------------------
Checks https://siteapps.deddie.gr/outages2public for planned outages in the
Municipality of Ierapetra (Prefecture of Lasithi), filters for rows that
mention the target villages/areas, and sends an email + WhatsApp (CallMeBot)
notification for any NEW outage it hasn't seen before.

State (which outages have already been notified) is kept in seen_outages.json
so the same outage isn't reported twice. This file is committed back to the
repo by the GitHub Actions workflow after each run.

Configuration is via environment variables (set as GitHub Actions Secrets):
  EMAIL_FROM            - sender Gmail address
  EMAIL_APP_PASSWORD    - Gmail app password (NOT your normal password)
  EMAIL_TO              - address to send alerts to
  CALLMEBOT_PHONE       - your WhatsApp number, international format, no "+"
  CALLMEBOT_APIKEY      - API key from CallMeBot

  AREA_KEYWORDS         - optional override, comma-separated (default below)
"""

import os
import re
import json
import sys
import hashlib
import smtplib
import unicodedata
from email.mime.text import MIMEText
from pathlib import Path

import requests
from bs4 import BeautifulSoup

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

BASE_URL = "https://siteapps.deddie.gr/Outages2Public"
INDEX_URL = f"{BASE_URL}/Home/Index"
PARTIAL_URL = f"{BASE_URL}/Home/OutagesPartial"

PREFECTURE_ID = 36   # Lasithiou
MUNICIPALITY_ID = 735  # Ierapetras

DEFAULT_KEYWORDS = ["Κουτσουναρι", "Φερμα"]  # accents stripped at match time
AREA_KEYWORDS = [
    k.strip() for k in os.environ.get(
        "AREA_KEYWORDS", ",".join(DEFAULT_KEYWORDS)
    ).split(",") if k.strip()
]

STATE_FILE = Path(__file__).parent / "seen_outages.json"

HEADERS = {
    "User-Agent": "Mozilla/5.0 (compatible; DeddieOutageWatch/1.0; "
                  "personal use script)"
}


def strip_accents(text: str) -> str:
    """Normalize Greek text so accented/unaccented versions match."""
    nfkd = unicodedata.normalize("NFKD", text)
    return "".join(c for c in nfkd if not unicodedata.combining(c)).upper()


# ---------------------------------------------------------------------------
# Scraping
# ---------------------------------------------------------------------------

def fetch_outage_rows():
    """
    Fetch all planned outage rows for the configured municipality.
    Returns a list of dicts with the parsed columns.
    """
    session = requests.Session()
    session.headers.update(HEADERS)

    rows = []
    page = 1
    while True:
        params = {
            "prefectureID": PREFECTURE_ID,
            "municipalityID": MUNICIPALITY_ID,
            "page": page,
        }
        # First page: hit the full Index page (this is what actually sets
        # the filter). Subsequent pages: hit the partial/pagination endpoint
        # within the same session so it reuses the filter that was set.
        url = INDEX_URL if page == 1 else PARTIAL_URL
        resp = session.get(url, params=params, timeout=30)
        resp.raise_for_status()

        soup = BeautifulSoup(resp.text, "html.parser")
        table = soup.find("table")
        if table is None:
            break

        page_rows = parse_table(table)
        if not page_rows:
            break

        rows.extend(page_rows)

        # Stop if there's no "next page" link/control, or after a sane cap
        if not soup.find(string=re.compile(r"Επόμεν|›|»")) or page > 15:
            break
        page += 1

    return rows


def parse_table(table):
    """
    Parse a DEDDIE outage HTML table into a list of dicts.
    Expected columns (Greek): Από, Έως, Δήμος/Κοινότητα, Περιγραφή περιοχής,
    Αρ. Σημειώματος, Σκοπός διακοπής (exact headers may vary slightly).
    """
    rows = []
    trs = table.find_all("tr")
    if not trs:
        return rows

    # Try to detect header positions so this survives minor column reorders
    header_cells = [c.get_text(strip=True) for c in trs[0].find_all(["th", "td"])]

    for tr in trs[1:]:
        cells = [c.get_text(strip=True) for c in tr.find_all("td")]
        if not cells or len(cells) < 3:
            continue
        row = {}
        for i, val in enumerate(cells):
            key = header_cells[i] if i < len(header_cells) else f"col_{i}"
            row[key] = val
        rows.append(row)

    return rows


def row_matches_area(row: dict) -> bool:
    """Check whether a row's area/description text mentions our target area."""
    haystack = strip_accents(" ".join(row.values()))
    return any(strip_accents(kw) in haystack for kw in AREA_KEYWORDS)


def row_id(row: dict) -> str:
    """Stable unique ID for a row, used to dedupe across runs."""
    raw = json.dumps(row, sort_keys=True, ensure_ascii=False)
    return hashlib.sha256(raw.encode("utf-8")).hexdigest()[:16]


# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------

def format_message(row: dict) -> str:
    lines = [f"Planned DEDDIE power outage - Koutsounari/Ferma area:"]
    for k, v in row.items():
        if v:
            lines.append(f"{k}: {v}")
    lines.append("\nSource: https://siteapps.deddie.gr/outages2public")
    return "\n".join(lines)


def send_email(subject: str, body: str):
    email_from = os.environ.get("EMAIL_FROM")
    email_password = os.environ.get("EMAIL_APP_PASSWORD")
    email_to = os.environ.get("EMAIL_TO")

    if not all([email_from, email_password, email_to]):
        print("Email not configured, skipping email notification.")
        return

    msg = MIMEText(body, "plain", "utf-8")
    msg["Subject"] = subject
    msg["From"] = email_from
    msg["To"] = email_to

    with smtplib.SMTP_SSL("smtp.gmail.com", 465) as server:
        server.login(email_from, email_password)
        server.sendmail(email_from, [email_to], msg.as_string())
    print("Email sent.")


def send_whatsapp(body: str):
    phone = os.environ.get("CALLMEBOT_PHONE")
    apikey = os.environ.get("CALLMEBOT_APIKEY")

    if not all([phone, apikey]):
        print("CallMeBot not configured, skipping WhatsApp notification.")
        return

    resp = requests.get(
        "https://api.callmebot.com/whatsapp.php",
        params={"phone": phone, "text": body, "apikey": apikey},
        timeout=30,
    )
    print(f"CallMeBot response ({resp.status_code}): {resp.text[:200]}")


# ---------------------------------------------------------------------------
# State
# ---------------------------------------------------------------------------

def load_seen():
    if STATE_FILE.exists():
        return set(json.loads(STATE_FILE.read_text(encoding="utf-8")))
    return set()


def save_seen(seen):
    STATE_FILE.write_text(
        json.dumps(sorted(seen), ensure_ascii=False, indent=2), encoding="utf-8"
    )


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    debug = "--debug" in sys.argv

    try:
        rows = fetch_outage_rows()
    except Exception as e:
        print(f"ERROR fetching outages: {e}", file=sys.stderr)
        sys.exit(1)

    if debug:
        print(f"Fetched {len(rows)} total rows for the municipality.")

    matching = [r for r in rows if row_matches_area(r)]

    if debug:
        print(f"{len(matching)} rows match AREA_KEYWORDS={AREA_KEYWORDS}")
        for r in matching:
            print(r)

    seen = load_seen()
    new_rows = [r for r in matching if row_id(r) not in seen]

    if not new_rows:
        print("No new matching outages.")
        return

    for row in new_rows:
        body = format_message(row)
        print("New outage found:\n" + body)
        send_email("Planned power outage - Koutsounari/Ferma", body)
        send_whatsapp(body)
        seen.add(row_id(row))

    save_seen(seen)


if __name__ == "__main__":
    main()
